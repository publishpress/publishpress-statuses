OPENAI_API_KEY=

WEBLATE_API_TOKEN=

TERMINAL_IMAGE_NAME="publishpress/dev-workspace-terminal:node-25"
WP_IMAGE_NAME="publishpress/dev-workspace-wordpress:wordpress-6.9-php-8.5"
WPCLI_IMAGE_NAME="publishpress/dev-workspace-wpcli:wpcli-2-php-8.5"

PLUGIN_NAME="PublishPress Statuses"
PLUGIN_TYPE="FREE"
PLUGIN_COMPOSER_PACKAGE="publishpress/publishpress-statuses"

TRANSLATION_OVERRIDES="PublishPress,PublishPress Statuses,PublishPress Statuses Free,PublishPress Statuses Pro,Statuses Pro,publishpress.com"

# Docker container name
CONTAINER_NAME="publishpress-statuses"

# Path to the cache directory for the dev-workspace
CACHE_PATH="./.cache"

# The slug of the plugin to be tested.
PLUGIN_SLUG="publishpress-statuses"

# The domain of the plugin to be tested.
LANG_DOMAIN="publishpress-statuses"

# The directory of the language files.
LANG_DIR="languages"

LANG_LOCALES="de_DE es_ES fi fil fr_FR id_ID it_IT ja ko_KR nl_NL pt_BR ru_RU yor"
