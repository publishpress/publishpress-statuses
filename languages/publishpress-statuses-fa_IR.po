msgid "Standard Publication:"
msgstr "انتشار استاندارد:"

#: StatusListTable.php:524
msgid "Visibility Statuses for Private Publication:"
msgstr "وضعیت‌های نمایش برای انتشار خصوصی:"

#: StatusListTable.php:531
