{
    "name": "publishpress/publishpress-statuses",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "description": "",
    "authors": [
        {
            "name": "PublishPress",
            "email": "help@publishpress.com",
            "homepage": "https://publishpress.com",
            "role": "Developer"
        }
    ],
    "config": {
        "preferred-install": {
            "*": "dist"
        },
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "phpstan/extension-installer": true,
            "publishpress/dev-workspace": true,
            "php-http/discovery": true
        },
        "process-timeout": 0
    },
    "prefer-stable": true,
    "minimum-stability": "dev",
    "require": {
        "php": ">=7.2.5",
        "ext-json": "*"
    },
    "require-dev": {
        "publishpress/dev-workspace": "^1.3"
    },
    "extra": {
        "plugin-slug": "publishpress-statuses",
        "plugin-name": "publishpress-statuses",
        "plugin-folder": "publishpress-statuses",
        "version-constant": "PUBLISHPRESS_STATUSES_VERSION",
        "plugin-lang-domain": "publishpress-statuses",
        "plugin-github-repo": "publishpress/publishpress-statuses",
        "plugin-composer-package": "publishpress/publishpress-statuses"
    }
}
